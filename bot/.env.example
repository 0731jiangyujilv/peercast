# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/betsys

# Server
PORT=3000

# Base Sepolia (for Telegram bot)
RPC_URL=https://base-sepolia-public.nodies.app
CHAIN_ID=84532
BET_FACTORY_ADDRESS=0x65F971b490c9f5afcE465b9eEfCEFC91d25483c6
USDC_ADDRESS=0x0000000000000000000000000000000000000000

# World Chain Sepolia (for Mini App)
WORLD_CHAIN_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public
WORLD_CHAIN_ID=4801
WORLD_PREDICTION_FACTORY_ADDRESS=0xFAE423C82F4615ffc41fa17eDC3cBf5C8b219BEC
WORLD_USDC_ADDRESS=0x79A02482A880bCE3F13e09Da970dC34db4CD24d1

# WebApp (Telegram Mini App URL — deployed webapp)
WEBAPP_URL=https://betsys.example.com

# Operator private key (authorized to call BetFactory.createPrediction)
OPERATOR_PRIVATE_KEY=your_operator_private_key_here

# Basescan API key (for auto-verifying Bet contracts)
BASESCAN_API_KEY=your_basescan_api_key

# Path to contracts directory (for forge verify-contract)
CONTRACTS_PATH=../contracts
